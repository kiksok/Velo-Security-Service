PORT=3000
BACKEND_PANEL=xb
BACKEND_DOMAIN=http://127.0.0.1:3000
SEC_PASSWORD=change-this-to-a-long-random-secret

# Hardened public surface.
HARDENED_MODE=true
RPC_PATH=/assets/event
ALLOWED_ORIGINS=https://your-theme-domain.example
RPC_PROXY_ENABLED=false
DEBUG_LOGS=false

# Optional admin bridge for quick checkout.
ADMIN_API_PREFIX=
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_CREATE_USER_ENABLED=false

# Optional SMTP for quick checkout account notification.
MAIL_HOST=
MAIL_PORT=465
MAIL_SECURE=true
MAIL_USER=
MAIL_PASS=
MAIL_NEWUSER_SUBJECT=Welcome
MAIL_NEWUSER_URL=

# Optional captcha.
CAPTCHA_KEY=
CAPTCHA_QUICK_ORDER_ENABLED=true
CAPTCHA_REGISTER_ENABLED=true
CAPTCHA_LOGIN_ENABLED=true

# Optional outbound proxy for backend requests.
PROXY_URL=
